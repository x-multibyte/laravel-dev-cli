{
    "preset": "psr12",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "new_with_parentheses": {
            "anonymous_class": false,
            "named_class": false
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_import_per_statement": true,
        "no_unused_imports": true
    }
}
